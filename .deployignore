# .deployignore — patterns excluded from every console deploy
# One glob pattern per line. Matched against archive paths by tar --exclude-from.
# Add new large or host-only paths here rather than touching deploy.sh.

# ── Version control ───────────────────────────────────────────────────────────
.git

# ── Python runtime artifacts ──────────────────────────────────────────────────
__pycache__
*.pyc

# ── Local-only tools ──────────────────────────────────────────────────────────
.venv
dev.py
deploy.sh
.deployignore

# ── Templates (real .env files are deployed; samples are not) ─────────────────
*.env.sample

# ── Web / Node build artifacts ────────────────────────────────────────────────
node_modules

# ── IDE and OS artifacts ──────────────────────────────────────────────────────
.idea
.DS_Store
.claude

# ── Large per-console asset directories ──────────────────────────────────────
# These live natively on the device. Never push from the host machine.
roms
bin
share

# ── Runtime logs and ephemeral state ─────────────────────────────────────────
*.log
