# ─────────────────────────────
#  VMU reader -- environment template
#  Copy to .env and fill in the values.
#  Only *.env.sample is committed; never .env.
# ─────────────────────────────

# Identity
NODE_NAME=VMU

# Network
# HOST_IP is host:port -- the Pi hub's sync server health endpoint (/health).
# Unlike other nodes this is a port-based check, not ICMP: returns 200 when the
# DreamPicoPort USB reader is detected, 503 when it isn't. The Pi must be up and
# cpc-hub.service running for the check to reach it.
HOST_IP=192.168.68.60:7721

# UI Branding (hex)
UI_PRIMARY_COLOR=#C51A4A
UI_SECONDARY_COLOR=#7A1533
