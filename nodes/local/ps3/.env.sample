# ─────────────────────────────
#  PlayStation 3 — environment template
#  Copy to .env (or dev.env / prod.env) and fill in the values.
#  Only *.env.sample is committed; never .env.
# ─────────────────────────────

# Identity
NODE_NAME="PlayStation 3"
MANUFACTURER=Sony

# Network
HOST_IP=
# PLUTO_IP: IP of the machine running the Pluto dashboard (api.py).
# Set to enable the Chat menu item. Leave empty to hide it.
PLUTO_IP=
# FILES button: a folder URL to open. Use SMB_PATH on Linux/Windows nodes, or
# FTP_PATH on a jailbroken console (a PS3's webMAN/multiMAN FTP daemon on port 21).
# Set only one. Include auth in the URL if the daemon needs it.
#   SMB guest:  smb://guest:@hostname
#   SMB authed: smb://user:password@hostname
#   PS3 FTP:    ftp://192.168.x.x   (webMAN FTPd accepts any login; anonymous is fine)
SMB_PATH=
FTP_PATH=
# SSH: set CUSTOM_SSH_ALIAS (ssh-config entry) OR SSH_USER + SSH_KEY_PATH.
# Having either enables the DEPLOY button in Pluto. Omit both for a files-only
# node (e.g. a third-party distro you don't deploy the TUI to).
CUSTOM_SSH_ALIAS=
SSH_USER=
SSH_KEY_PATH=~/.ssh/id_rsa

# UI Branding (hex, e.g. #00FF88)
UI_PRIMARY_COLOR=#003791
UI_SECONDARY_COLOR=#1A3D6E

