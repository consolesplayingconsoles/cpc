NODE_NAME=Roomba Rally

# Control target group: this node is a subtarget of the "roomba" target in the
# Control rail (source -> target -> subtarget). Nodes sharing a value are grouped.
CONTROL_TARGET=roomba

# Pico W network (station mode). HOST_IP is host:port -- Pluto calls GET /health
# there instead of ICMP ping. Leave empty here; set the real value in .env.
HOST_IP=
HOST_PORT=7724

# Wi-Fi credentials (Pico connects to your home network)
ROOMBA_SSID=YourHomeNetworkSSID
ROOMBA_PASSWORD=your_password_here
