# SGDK build output -- regenerate with the docker build (see README.md)
*/out/

# rescomp-generated from res/*.res at build time (not source)
*/res/*.h
*/res/*.rs

# SGDK-generated boot stubs (created into src/boot/ by makefile.gen at build)
*/src/boot/

# raw third-party CC0 asset packs (downloaded; the derived res/*.png IS committed)
*/assets/
*.zip
