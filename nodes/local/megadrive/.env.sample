# ─────────────────────────────
#  Mega Drive — environment template
#  Copy to .env (or dev.env / prod.env) and fill in the values.
#  Only *.env.sample is committed; never .env.
# ─────────────────────────────

# Identity (the node key is the dir name: "smd")
NODE_NAME=Mega Drive
MANUFACTURER=Sega

# Network
# HOST_IP: the Mega Drive has no IP of its own -- it reaches the network through the
# genesis datalink Pico on the Pi hub. Point this at the hub's health server as
# <pi_ip>:<port> (e.g. 192.168.68.60:7722, matching the Pi's PI_MD_HEALTH_PORT). Pluto
# then does a TCP + GET /health there instead of an ICMP ping: up = the console is
# actually powered (the Pico sees SELECT toggling), down = off. Empty = not on the map.
HOST_IP=
# PLUTO_IP: IP of the machine running the Pluto dashboard (api.py).
# Set to enable the Chat menu item. Leave empty to hide it.
PLUTO_IP=

# UI Branding (hex)
UI_PRIMARY_COLOR=#C0392B
UI_SECONDARY_COLOR=#7E2520
