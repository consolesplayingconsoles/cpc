# ─────────────────────────────
#  Google — cloud connector (off-network: no IP, never pinged)
#  Google Cloud API key used by Pluto for Vision (text detection) and Translation.
#  Copy to .env to override. Only *.env.sample is committed; never .env.
# ─────────────────────────────

# Identity (key = dir name)
NODE_NAME=Google

# ── Google API key ──────────────────────────────────────────────────────
# Google Cloud API key used for both Cloud Vision (text detection) and Cloud
# Translation (subtitle translation). Not a service-account JSON -- a simple
# API key is enough. Create one at console.cloud.google.com under
# APIs & Services -> Credentials. Enable "Cloud Vision API" and
# "Cloud Translation API" for the project.
# Leaving this blank keeps the node unconfigured (shown greyed-out in the diagram).
GOOGLE_API_KEY=

# Default target language for translation (BCP-47 code: en, ca, es, fr …).
# Used by the hardware trigger (DC controller L+R) and as the UI picker default.
LENS_LANG=en
