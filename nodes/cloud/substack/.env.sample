# ─────────────────────────────
#  Substack — cloud connector (off-network: no IP, never pinged)
#  Copy to .env to override. Only *.env.sample is committed; never .env.
# ─────────────────────────────

# Identity (key = dir name)
NODE_NAME=Substack

# ── Sender creds (the `@substack post <title>\n<body>` chat verb) ──────────────
# Used by api/modules/substack/sender.py to log in and create a DRAFT (it never
# publishes — you review & publish from Substack). All three are REQUIRED; leave
# them blank and the verb just replies "not configured". Filling a real .env here
# also flips the node from "unconfigured" to live on the diagram + chat.
# Substack has no public API (endpoints are reverse-engineered) — restart the API
# after editing, and confirm the first post lands.
#
# SUBSTACK_EMAIL / SUBSTACK_PASSWORD: your Substack login. PASSWORD accounts only —
#   if your account is magic-link/SSO-only, set a password in Substack first
#   (Settings -> account), or login will 403.
SUBSTACK_EMAIL=
SUBSTACK_PASSWORD=
# SUBSTACK_PUBLICATION_URL: your publication's full origin, no trailing path.
#   e.g. https://yourname.substack.com  (custom domains also work)
SUBSTACK_PUBLICATION_URL=
