# ─────────────────────────────
#  BirdBuddy — environment template
#  Copy to .env (or dev.env / prod.env) and fill in the values.
#  Only *.env.sample is committed; never .env.
# ─────────────────────────────

# Identity
NODE_NAME=BirdBuddy
SHORT_NAME=birdbuddy
MANUFACTURER=Bird Buddy

# Network
# The BirdBuddy feeder squats a LAN IP — the "ip thief". Set it here so the node
# shows on the Pluto map; status is a live ping like any other device. There is
# no software integration (the account uses social login, which the API can't do),
# this node is here purely to honor the freeloader on the network.
HOST_IP=
# PLUTO_IP: IP of the machine running the Pluto dashboard (api.py).
PLUTO_IP=

# UI Branding (hex)
UI_PRIMARY_COLOR=#2DBE9C
UI_SECONDARY_COLOR=#1C7A66
