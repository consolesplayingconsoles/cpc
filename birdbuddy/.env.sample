# ─────────────────────────────────────────────
#  consolesplayingconsoles — environment template
#  Copy to .env and fill in values.
#  Do NOT commit files with real data.
# ─────────────────────────────────────────────

# Identity
NODE_NAME=BirdBuddy
SHORT_NAME=birdbuddy
MANUFACTURER=Bird Buddy

# Network
# BirdBuddy is a cloud device — there is no LAN IP to ping. Its graph status
# follows the postcard poller instead (online when the cloud feed is reachable).
HOST_IP=
# PLUTO_IP: IP of the machine running the Pluto dashboard (api.py).
PLUTO_IP=

# BirdBuddy account — password login only (Google/SSO is not supported by the
# API). Lives here on Pluto only and is never deployed to consoles. Enables
# postcard events ("a bird visited the feeder") in the group chat.
# Requires `pip install pybirdbuddy` on the Pluto host.
BIRDBUDDY_EMAIL=
BIRDBUDDY_PASSWORD=
# How often to check the cloud feed. Floored at 120s — sightings are rare and
# also notify your phone, so there's no reason to poll harder. Raise to taste.
BIRDBUDDY_POLL_SECONDS=120

# UI Branding (hex)
UI_PRIMARY_COLOR=#2DBE9C
UI_SECONDARY_COLOR=#1C7A66
