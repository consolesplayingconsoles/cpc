{
  "_comment": "Keyboard source -> Roomba target, laid out as a DRIVING pad so a real gamepad (8BitDo over BT, added later as its own source) maps straight onto it. D-pad = STEERING + throttle (up/down/left/right); the face diamond = actions. 'actions' binds each btn to the verb the node's command stream runs (see nodes/local/roomba-rally/main.py send_command). 'combinations' fires a SINGLE arc verb when two d-pad dirs are held together (forward+left etc.) so you can turn WHILE moving -- the Roomba's Drive opcode takes velocity AND radius in one command, so a blended arc is one verb, not two fighting nudges. 'keys' bind the on-screen/physical keyboard; 'colors' tint the buttons.",
  "controller": "Roomba Rally",
  "kind": "drive",
  "controls": { "Enter": "START", "action": "A", "cancel": "B" },
  "actions": {
    "A": "horn",
    "B": "robot",
    "Y": "error",
    "X": "lights",
    "D_UP": "drive-forward",
    "D_DOWN": "drive-back",
    "D_LEFT": "turn-left",
    "D_RIGHT": "turn-right",
    "START": "session"
  },
  "combinations": {
    "D_UP+D_LEFT": "forward-left",
    "D_UP+D_RIGHT": "forward-right",
    "D_DOWN+D_LEFT": "back-left",
    "D_DOWN+D_RIGHT": "back-right"
  },
  "keys": {
    "A": "k", "B": "l", "X": "j", "Y": "i",
    "D_UP": "w", "D_DOWN": "s", "D_LEFT": "a", "D_RIGHT": "d", "START": "enter"
  },
  "layout": [
    { "key": "q", "btn": "L", "label": "L", "col": 2, "row": 1 },
    { "key": "p", "btn": "R", "label": "R", "col": 8, "row": 1 },
    { "key": "w", "btn": "D_UP",    "label": "Up",    "col": 2, "row": 2 },
    { "key": "a", "btn": "D_LEFT",  "label": "Left",  "col": 1, "row": 3 },
    { "key": "d", "btn": "D_RIGHT", "label": "Right", "col": 3, "row": 3 },
    { "key": "s", "btn": "D_DOWN",  "label": "Down",  "col": 2, "row": 4 },
    { "key": "Enter", "btn": "START", "label": "Start", "col": 5, "row": 3 },
    { "key": "i", "btn": "Y", "label": "Y", "col": 8, "row": 2 },
    { "key": "j", "btn": "X", "label": "X", "col": 7, "row": 3 },
    { "key": "l", "btn": "B", "label": "B", "col": 9, "row": 3 },
    { "key": "k", "btn": "A", "label": "A", "col": 8, "row": 4 }
  ],
  "colors": {
    "L": "#8a9099", "R": "#8a9099",
