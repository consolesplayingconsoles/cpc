{
  "_comment": "DreamPicoPort source -> Roomba target. Same driving-pad layout as keyboard/roomba.json (so the SE on-screen/physical keyboard assist works identically) with the confirmed gamepad indices added as extra `actions` keys pointing at the SAME verbs. Gamepad indices from the regular pad, confirmed live via DreamPicoPortControl: buttons 0=A,1=B,3=X,4=Y,11=Start; axis0=left stick X, axis2=left trigger, axis5=right trigger, axis9=dpad(unconfirmed values). Triggers are BUTTONS for forward/back (operator's call): axis5(+)=drive-forward, axis2(+)=drive-back; turn-left/right uses axis0 sign. NOTE: no runtime consumer reads the AXIS/BTN keys yet -- ControlKeyboard only reads keyboard input; a gamepad-driving component is the next piece to build.",
  "controller": "Roomba Rally",
  "kind": "drive",
  "controls": { "Enter": "START", "action": "A", "cancel": "B" },
  "actions": {
    "A": "horn",
    "B": "safety",
    "Y": "dock",
    "X": "listen",
    "D_UP": "drive-forward",
    "D_DOWN": "drive-back",
    "D_LEFT": "turn-left",
    "D_RIGHT": "turn-right",
    "START": "session",
    "AXIS5+": "drive-forward",
    "AXIS2+": "drive-back",
    "AXIS0-": "turn-left",
    "AXIS0+": "turn-right",
    "BTN0": "horn",
    "BTN1": "safety",
    "BTN4": "dock",
    "BTN3": "listen",
    "BTN11": "session"
  },
  "combinations": {
    "D_UP+D_LEFT": "forward-left",
    "D_UP+D_RIGHT": "forward-right",
    "D_DOWN+D_LEFT": "back-left",
    "D_DOWN+D_RIGHT": "back-right"
  },
  "keys": {
    "A": "k", "B": "l", "X": "j", "Y": "i",
    "D_UP": "w", "D_DOWN": "s", "D_LEFT": "a", "D_RIGHT": "d", "START": "enter"
  },
  "layout": [
    { "key": "q", "btn": "L", "label": "L", "col": 2, "row": 1 },
    { "key": "p", "btn": "R", "label": "R", "col": 8, "row": 1 },
    { "key": "w", "btn": "D_UP",    "label": "Up",    "col": 2, "row": 2 },
    { "key": "a", "btn": "D_LEFT",  "label": "Left",  "col": 1, "row": 3 },
    { "key": "d", "btn": "D_RIGHT", "label": "Right", "col": 3, "row": 3 },
    { "key": "s", "btn": "D_DOWN",  "label": "Down",  "col": 2, "row": 4 },
    { "key": "Enter", "btn": "START", "label": "Start", "col": 5, "row": 3 },
    { "key": "i", "btn": "Y", "label": "Dock",  "col": 8, "row": 2 },
    { "key": "j", "btn": "X", "label": "Listen", "col": 7, "row": 3 },
    { "key": "l", "btn": "B", "label": "Safe",  "col": 9, "row": 3 },
    { "key": "k", "btn": "A", "label": "Honk",  "col": 8, "row": 4 }
  ],
  "colors": {
    "L": "#8a9099", "R": "#8a9099",
    "D_UP": "#4b5058", "D_DOWN": "#4b5058", "D_LEFT": "#4b5058", "D_RIGHT": "#4b5058",
    "A": "#d63b34", "B": "#2d8ec9", "X": "#edba1f", "Y": "#36a657",
    "START": "#8a9099"
  }
}
