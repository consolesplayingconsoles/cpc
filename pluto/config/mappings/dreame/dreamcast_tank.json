{
  "_comment": "Dreame events => Dreamcast, tank/relative steering (the GTA2 scheme): hold accelerate-forward, steer left/right on turns -- GTA2's movement is non-standard. For plain heading-follow movement use dreamcast_dpad / gamecube_dpad instead. 'keys' = the DC/Flycast binding (we run it there, never the PS1 one): X=accelerate (FWD), D=reverse (REV), arrows=steer. Edit 'keys' if your binding differs. Tune the turn pulse ms for sharper/softer steering; lower events.TURN_DEG for more frequent steering.",
  "controller": "Dreamcast (tank / relative steering, e.g. GTA2)",
  "controls": { "Enter": "START", "action": "A", "cancel": "B" },
  "keys": { "FWD": "x", "REV": "d", "STEERL": "left", "STEERR": "right" },
  "layout": [
    { "key": "q", "btn": "L", "label": "L", "col": 2, "row": 1 },
    { "key": "p", "btn": "R", "label": "R", "col": 8, "row": 1 },
    { "key": "w", "btn": "D_UP",    "label": "Up",    "col": 2, "row": 2 },
    { "key": "a", "btn": "D_LEFT",  "label": "Left",  "col": 1, "row": 3 },
    { "key": "d", "btn": "D_RIGHT", "label": "Right", "col": 3, "row": 3 },
    { "key": "s", "btn": "D_DOWN",  "label": "Down",  "col": 2, "row": 4 },
    { "key": "Enter", "btn": "START", "label": "Start", "col": 5, "row": 3 },
    { "key": "i", "btn": "Y", "label": "Y", "col": 8, "row": 2 },
    { "key": "j", "btn": "X", "label": "X", "col": 7, "row": 3 },
    { "key": "l", "btn": "B", "label": "B", "col": 9, "row": 3 },
    { "key": "k", "btn": "A", "label": "A", "col": 8, "row": 4 }
  ],
  "colors": {
    "L": "#8a9099", "R": "#8a9099",
    "D_UP": "#4b5058", "D_DOWN": "#4b5058", "D_LEFT": "#4b5058", "D_RIGHT": "#4b5058",
    "A": "#d63b34", "B": "#2d8ec9", "X": "#edba1f", "Y": "#36a657",
    "START": "#8a9099"
  },
  "rules": {
    "start":      { "press": "FWD" },
    "turn":       { "left":  { "pulse": "STEERL", "ms": 160 },
                    "right": { "pulse": "STEERR", "ms": 160 } },
    "reposition": { "pulse": "REV", "ms": 140 },
    "end":        { "release_all": true }
  }
}
