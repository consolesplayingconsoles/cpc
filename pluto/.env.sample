# ─────────────────────────────────────────────
#  Pluto — environment template
#  Copy to .env and fill in values.
#  Do NOT commit files with real data.
# ─────────────────────────────────────────────

# UI Branding
NODE_NAME=
UI_PRIMARY_COLOR=
UI_SECONDARY_COLOR=

# Network
# HOST_IP: the box this dashboard is deployed to. Pluto appears on its own map
# as a normal node at this IP, pinged live — never a phantom localhost entry.
HOST_IP=
# CUSTOM_SSH_ALIAS: ~/.ssh/config Host alias for deploys (DEPLOY button). With it
# set you don't need SSH_USER/SSH_KEY_PATH.
CUSTOM_SSH_ALIAS=
GATEWAY_IP=
# Optional OS override for the pluto node's badge (else guessed from ping TTL).
OS=

# Optional buttons on the pluto node. Each renders only when its var is set.
# SMB_PATH:      FILES button — share opened client-side in the viewer's browser.
SMB_PATH=
# WORKSPACE_PATH: CODE button — opened in the IDE on the API host (dev only).
WORKSPACE_PATH=

# AI Services
# @claude chat bot. Three states:
#   1. ANTHROPIC_API_KEY set            -> real Claude, on your own key.
#   2. no key + CLAUDE_BROKE_MODE=1     -> the gag: @claude joins but is
#      perpetually broke, no API call, no cost. Mention it and it blinks
#      offline with a funny "INSERT COIN" line. Free forever.
#   3. neither                          -> bot disabled, ships clean.
# The key (when set) lives on Pluto only and is never deployed to consoles.
# Get one at console.anthropic.com when you're ready to reinvest.
ANTHROPIC_API_KEY=
# Optional model override. Defaults to a cheap, fast Claude model.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Set to 1 to run the keyless broke-mode gag (ignored when a key is present).
CLAUDE_BROKE_MODE=1

# Cloud service buddies — Pluto's off-network companions, drawn as a separate
# "solar system" below the LAN: a hub hangs off the gateway and fans out to these.
# They are NOT network nodes — no console dir, no ping. A buddy appears only when
# configured here; leave a *_NAME blank to strip it from the map. Namespaced so a
# different backend could be hooked later without code changes. Keep provider
# brand names OUT of this committed template — put the real name in your own .env.
#
# Commercial cloud storage the consoles sync through.
CLOUD_STORAGE_NAME=
# CLOUD_STORAGE_COLOR=#0061ff
#
# LLM agent node. The assistant itself is enabled by ANTHROPIC_API_KEY /
# CLAUDE_BROKE_MODE above; these only rebrand its cloud node (name defaults to
# "Claude" when blank).
# LLM_AGENT_NAME=
# LLM_AGENT_COLOR=#d97757

# Robutek (DreameHome cloud) tab. Optional — path to the dreamehome-client repo
# the API imports in-process for live vacuum state + routes. Defaults to
# ../../dreamehome-client (sibling of the cpc repo). The pure-stdlib lib needs no
# venv. Sign in from the Robutek tab (the password manager remembers; the API
# holds the session in memory, never on disk). Best opened via http://pluto.localhost
# so the password manager treats Pluto as its own origin.
DREAME_CLIENT_PATH=
