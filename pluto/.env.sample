# ─────────────────────────────────────────────
#  Pluto — environment template
#  Copy to .env and fill in the values. Only *.env.sample is committed; never .env.
# ─────────────────────────────────────────────

# ── Identity & branding ──────────────────────────────────────────────────────
# NODE_NAME: host identity, shown as the page title (e.g. "Pluto - Dev Node").
NODE_NAME=
# UI_PRIMARY_COLOR / UI_SECONDARY_COLOR: accent + secondary used across the UI.
UI_PRIMARY_COLOR=
UI_SECONDARY_COLOR=

# ── Network ──────────────────────────────────────────────────────────────────
# GATEWAY_IP: the LAN gateway. REQUIRED — the app refuses to boot without it.
GATEWAY_IP=
# HOST_IP: the box this dashboard runs on. Pluto draws itself as a normal node at
# this IP and pings it live (no phantom localhost entry).
HOST_IP=
# OS: optional badge override for the pluto node (otherwise guessed from ping TTL).
OS=

# ── Deploy / access ──────────────────────────────────────────────────────────
# CUSTOM_SSH_ALIAS: ~/.ssh/config Host alias used by the DEPLOY button. Set this
# and you don't need a separate SSH_USER / SSH_KEY_PATH.
CUSTOM_SSH_ALIAS=

# ── Optional pluto-node buttons (each shows only when its value is set) ────────
# SMB_PATH:       FILES button — share opened client-side in the viewer's browser.
SMB_PATH=
# WORKSPACE_PATH: CODE button — opened in the IDE on the API host (dev only).
WORKSPACE_PATH=

# ── AI assistant (@claude in chat) ───────────────────────────────────────────
# ANTHROPIC_API_KEY: set to enable the real assistant on your own key. Leave blank
# and set CLAUDE_BROKE_MODE=1 to keep @claude present as a no-cost stub (it replies
# that it's "broke" instead of calling the API). With neither, the bot is disabled.
# The key stays on Pluto and is never deployed to consoles.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL: model override (defaults to a small, fast Claude model).
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# CLAUDE_BROKE_MODE: 1 = keyless stub mode (ignored when a key is set).
CLAUDE_BROKE_MODE=1

# ── Cloud cluster (the off-network "solar system" on the diagram) ─────────────
# These are not network nodes — no ping, no console dir; just connectors Pluto
# reaches over the internet. Swappable backends are NAMED here (the name is the
# node's on-diagram label, and the node appears only once named); keep brand names
# out of this committed template and set yours in .env.
#
# CLOUD_STORAGE_NAME: the cloud drive the consoles sync through. Blank = no node.
CLOUD_STORAGE_NAME=
# CLOUD_STORAGE_COLOR: optional accent override for that node.
# CLOUD_STORAGE_COLOR=
# LLM_AGENT_NAME / LLM_AGENT_COLOR: relabel/recolour the assistant's node (enabled
# by ANTHROPIC_API_KEY above; defaults to "Claude"). Optional.
# LLM_AGENT_NAME=
# LLM_AGENT_COLOR=
#
# DreameHome (the vacuum's cloud) and Substack (the publish target) are fixed
# services, not swappable, so there's nothing to name — their nodes are always drawn.

# ── DreameHome integration ───────────────────────────────────────────────────
# The API imports the `dreamehome` client (pure stdlib) to read live vacuum state
# + cleaning routes and to sign in from the Dreame tab. Normally it's just an
# installed package (pip install dreamehome) — nothing to configure here.
# DREAME_CLIENT_PATH is an OPTIONAL fallback: point it at a local checkout of the
# client repo if it isn't installed. Unset, it defaults to ../../dreamehome-client
# (sibling of this repo), which covers the dev workflow. Sign-in is allowed from
# the local network; the session is held in memory, never written to disk.
# DREAME_CLIENT_PATH=
