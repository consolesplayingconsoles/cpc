# ─────────────────────────────
#  Wii — environment template
#  Copy to .env (or dev.env / prod.env) and fill in the values.
#  Only *.env.sample is committed; never .env.
# ─────────────────────────────

# Identity
NODE_NAME=Wii
SHORT_NAME=wii
MANUFACTURER=Nintendo
# OS: optional override for the Pluto bubble badge. Left blank, Pluto auto-detects
# the OS family from the ping reply TTL. Set "native" for a Wii homebrew (.dol)
# build so no penguin shows. Values: linux | macos | windows | native.
OS=

# Network
HOST_IP=
# PLUTO_IP: IP of the machine running the Pluto dashboard (api.py).
# Set to enable the Chat menu item. Leave empty to hide it.
PLUTO_IP=
# BT_MAC: Wii Bluetooth address — used by bridge scripts on peer devices
BT_MAC=
# SMB_PATH enables the FILES button in Pluto. Include auth in the URL if needed:
# guest:  smb://guest:@hostname
# authed: smb://user:password@hostname
SMB_PATH=
# SSH: set CUSTOM_SSH_ALIAS (ssh-config entry) OR SSH_USER + SSH_KEY_PATH.
# Having either enables the DEPLOY button in Pluto. Omit both for a files-only
# node (e.g. a third-party distro you don't deploy the TUI to).
CUSTOM_SSH_ALIAS=
SSH_USER=
SSH_KEY_PATH=~/.ssh/id_rsa

# UI Branding (hex, e.g. #00FF88)
UI_PRIMARY_COLOR=#75B2DD
UI_SECONDARY_COLOR=#7A9BAA


# Game library paths — leave empty to hide from menu. Disk must be mounted.
# GC: each subdirectory is a game title.
# Wii: each subdirectory name is the title (ignore the .wbfs filename inside).
GC_GAMES_PATH=/mnt/usb/games
WII_GAMES_PATH=/mnt/usb/wbfs

